{
  "name": "breath-city-design-system",
  "type": "module",
  "version": "1.0.0",
  "description": "Design system tokens for Breathe Cities — compiles to CSS custom properties and Tailwind theme",
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:tokens && next build",
    "start": "next start",
    "lint": "next lint",
    "build:tokens": "style-dictionary build --config style-dictionary.config.js",
    "watch:tokens": "nodemon --watch tokens --ext json --exec 'npm run build:tokens'"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.9",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.8",
    "style-dictionary": "^4.3.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  }
}
