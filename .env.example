# Breathe Cities — breath-city-test environment template
# Copy to .env.local and fill in real values. .env.local is gitignored — never commit secrets.

# Mapbox GL JS access token. Public (browser-exposed) by design — scope/restrict it in the
# Mapbox dashboard. Required by the map prototypes.
NEXT_PUBLIC_MAPBOX_TOKEN=

# OpenAQ v3 API key. SERVER-ONLY — never prefix with NEXT_PUBLIC, never log, never send to the
# client. Read by src/lib/openaq/client.ts on the server. Register at explore.openaq.org/register.
OPENAQ_API_KEY=
